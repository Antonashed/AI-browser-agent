# === LLM ===
ANTHROPIC_API_KEY=sk-ant-...
LLM_MODEL=claude-sonnet-4-20250514
LLM_MAX_TOKENS=4096

# === Агент ===
MAX_AGENT_STEPS=50
SCREENSHOT_ENABLED=true

# === MCP Browser ===
MCP_BROWSER_COMMAND=npx
MCP_BROWSER_ARGS=@playwright/mcp
BROWSER_HEADLESS=false
BROWSER_VIEWPORT_WIDTH=1280
BROWSER_VIEWPORT_HEIGHT=900
BROWSER_STORAGE_PATH=browser_state.json

# === CDP (подключение к уже открытому браузеру) ===
# По умолчанию агент подключается к уже запущенному Chrome.
# Запустите Chrome: chrome.exe --remote-debugging-port=9222
# Для автономного режима (MCP запускает свой браузер): CDP_ENDPOINT=none
CDP_ENDPOINT=http://localhost:9222

# === Лимиты ===
MAX_EMAILS_TO_SCAN=20
MAX_VACANCIES=5

# === Данные пользователя ===
USER_FULL_NAME=
USER_PHONE=
USER_EMAIL=
DELIVERY_ADDRESS=
