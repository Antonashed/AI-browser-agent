# === LLM ===
ANTHROPIC_API_KEY=sk-ant-...
LLM_MODEL=claude-sonnet-4-20250514
LLM_MAX_TOKENS=4096

# === Proxy (VPN) ===
# Если VPN работает в режиме прокси, укажите адрес прокси.
# Все запросы к Anthropic API пойдут через него. MCP работает локально.
# Примеры: http://127.0.0.1:1080  socks5://127.0.0.1:1080
ANTHROPIC_PROXY=

# === Логирование ===
# Путь к файлу логов. Если не указан — логи идут в stderr (в основной терминал).
# Укажите файл, чтобы смотреть логи в отдельном терминале:
#   PowerShell: Get-Content agent.log -Wait -Tail 50
#   cmd:        tail -f agent.log  (или используйте PowerShell)
LOG_FILE=agent.log
LOG_LEVEL=INFO

# === Агент ===
MAX_AGENT_STEPS=50
SCREENSHOT_ENABLED=true

# === MCP Browser ===
MCP_BROWSER_COMMAND=npx
MCP_BROWSER_ARGS=@playwright/mcp
BROWSER_HEADLESS=false
BROWSER_VIEWPORT_WIDTH=1280
BROWSER_VIEWPORT_HEIGHT=900
BROWSER_STORAGE_PATH=browser_state.json

# === Лимиты ===
MAX_EMAILS_TO_SCAN=20
MAX_VACANCIES=5

# === Данные пользователя ===
USER_FULL_NAME=
USER_PHONE=
USER_EMAIL=
DELIVERY_ADDRESS=
